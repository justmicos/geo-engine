# =============================================================================
# GEOEngine — Environment Configuration (v2.0 Multi-Provider)
# =============================================================================
# This project is a fork of justmicos/geo-engine with multi-provider AI support
# =============================================================================

# ---------------------------------------------------------------------------
# Basic — Core application settings
# ---------------------------------------------------------------------------
SITE_NAME=GEOEngine
APP_PORT=18080
APP_TIMEZONE=UTC
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
POSTGRES_PASSWORD=
DB_EXPOSE_PORT=15432
REDIS_EXPOSE_PORT=16379
APP_LOCALE=en
GEOFLOW_PUBLIC_LOCALE=en

# ---------------------------------------------------------------------------
# AI Gateway — Universal multi-provider AI proxy (recommended)
# Set AI_GATEWAY_ENABLED=true and GEOFlow will route ALL AI requests through
# the AI Gateway at :19090, which automatically routes to the correct provider
# based on the model name prefix.
#
# When AI_GATEWAY_ENABLED=false, GEOFlow falls back to its built-in
# database-driven ai_models provider resolution.
# ---------------------------------------------------------------------------
AI_GATEWAY_ENABLED=false
AI_GATEWAY_PORT=19090

# =============================================================================
# CLOUD LLM PROVIDERS
# =============================================================================
# The AI Gateway routes requests by model name prefix.
# All providers support OpenAI-compatible Chat Completions format natively or
# are translated by the gateway.

# --- OpenAI ---
# Models: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo, o1, o3-mini, etc.
OPENAI_API_KEY=
OPENAI_ORG_ID=                     # optional org ID
OPENAI_MODEL=gpt-4o

# --- Anthropic Claude ---
# Models: claude-sonnet-4-20250514, claude-3.5-haiku, claude-3-opus, etc.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_VERSION=2023-06-01

# --- Google Gemini ---
# Models: gemini-2.5-pro, gemini-2.0-flash, gemini-1.5-pro, etc.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- DeepSeek ---
# Models: deepseek-chat, deepseek-reasoner
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Azure OpenAI ---
# https://portal.azure.com -> Azure OpenAI Service
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_MODEL=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- AWS Bedrock ---
# https://aws.amazon.com/bedrock/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=claude-sonnet-4-v2

# --- SiliconFlow ---
# https://siliconflow.cn/ — Chinese cloud provider, OpenAI-compatible
SILICONFLOW_API_KEY=
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# --- Zhipu AI (智谱) ---
# https://open.bigmodel.cn/
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-plus

# --- Moonshot / Kimi ---
# https://platform.moonshot.cn/
MOONSHOT_API_KEY=
MOONSHOT_MODEL=moonshot-v1-8k

# --- Baidu Qianfan (千帆) ---
# https://console.bce.baidu.com/qianfan/
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_MODEL=ernie-4.0

# --- Alibaba Qwen (通义千问) ---
# https://help.aliyun.com/zh/model-studio/
QWEN_API_KEY=
QWEN_MODEL=qwen-max

# =============================================================================
# LOCAL LLM PROVIDERS
# =============================================================================
# Local models run on your machine. The AI Gateway proxies to them.
# Use host.docker.internal (Docker) to reach the host machine.

# --- Ollama ---
# Install: https://ollama.ai/
# Start: ollama serve
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:72b         # or llama3.1:70b, deepseek-r1:32b, etc.

# --- LM Studio ---
# Start: Open LM Studio -> Start Server on port 1234
# Server is OpenAI-compatible at http://localhost:1234/v1
LMSTUDIO_BASE_URL=http://host.docker.internal:1234
LMSTUDIO_MODEL=qwen2.5-72b-gguf

# --- vLLM ---
# Start: vllm serve Qwen/Qwen2.5-72B-Instruct --port 8000
VLLM_BASE_URL=http://host.docker.internal:8000
VLLM_MODEL=qwen2.5-72b-instruct

# --- LocalAI ---
# https://localai.io/
LOCALAI_BASE_URL=http://host.docker.internal:8080
LOCALAI_MODEL=llama-3.1-8b-instruct

# --- llama.cpp ---
# Start: ./server -m model.gguf --port 8081
LLAMACPP_BASE_URL=http://host.docker.internal:8081
LLAMACPP_MODEL=qwen2.5-72b-q4km

# --- DeepSeek local vLLM (if you self-host) ---
LOCAL_DEEPSEEK_BASE_URL=http://host.docker.internal:8000
LOCAL_DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3

# =============================================================================
# EMBEDDING MODEL
# =============================================================================
# AI Gateway proxies embeddings requests to the configured provider.
EMBEDDING_PROVIDER=openai         # openai | deepseek | ollama | local
EMBEDDING_MODEL=text-embedding-3-small
# For local embeddings via Ollama:
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# MODEL SELECTION (GEOFlow runtime default)
# =============================================================================
# These set the default model GEOFlow uses for content generation.
# Override per-task in the admin UI.
AI_MODEL=deepseek-chat
AI_API_URL=https://api.deepseek.com/v1
AI_API_KEY=

# =============================================================================
# KNOWLEDGE EVOLUTION
# =============================================================================
# Autonomous knowledge base improvement — periodically scans, merges,
# summarizes, cross-references, and prunes knowledge base content.
EVOLUTION_ENABLED=true
EVOLUTION_INTERVAL_HOURS=24       # how often the evolution job runs
EVOLUTION_MODEL=deepseek-chat     # model used for evolution AI tasks
EVOLUTION_MAX_CHUNKS_PER_RUN=50   # max chunks to process per run
EVOLUTION_SIMILARITY_THRESHOLD=0.85  # cosine similarity for duplicate detection
EVOLUTION_AUTO_PRUNE=true         # auto-archive low-quality chunks
EVOLUTION_AUTO_MERGE=true         # auto-merge similar chunks
EVOLUTION_AUTO_SUMMARIZE=true     # auto-generate summaries
EVOLUTION_AUTO_LINK=true          # auto-generate cross-references
EVOLUTION_AUTO_ARCHIVE_DAYS=90    # archive chunks not accessed in N days

# =============================================================================
# FINE-TUNING
# =============================================================================
# Local model fine-tuning using Unsloth (LoRA/QLoRA).
# Requires: NVIDIA GPU with CUDA 12.1+ (or AMD ROCm)
FINE_TUNE_ENABLED=false
FINE_TUNE_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct  # HuggingFace model name
FINE_TUNE_METHOD=lora              # lora | qlora | full
FINE_TUNE_R=16                     # LoRA rank
FINE_TUNE_ALPHA=32                 # LoRA alpha
FINE_TUNE_DROPOUT=0.1              # LoRA dropout
FINE_TUNE_BATCH_SIZE=4
FINE_TUNE_EPOCHS=3
FINE_TUNE_LEARNING_RATE=2e-4
FINE_TUNE_OUTPUT_DIR=/app/fine-tune/output
FINE_TUNE_DATASET_SOURCE=knowledge_base  # knowledge_base | qa_logs | both
FINE_TUNE_DATASET_MAX_SAMPLES=1000       # max training samples to collect
FINE_TUNE_DATASET_MIN_SCORE=0.7          # min quality score to include

# =============================================================================
# ADVANCED
# =============================================================================
# Gateway & fine-tuning container runtime options
AI_GATEWAY_WORKERS=1              # uvicorn workers
AI_GATEWAY_LOG_LEVEL=info         # debug | info | warning | error
FINE_TUNE_GPU_DEVICES=all         # GPU devices for fine-tuning
